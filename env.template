# Sao chép thành .env:
#   Windows (PowerShell): Copy-Item env.template .env
#   Linux / WSL / Git Bash: cp env.template .env
# --- Bắt buộc cho production (đổi toàn bộ giá trị mặc định) ---
MYSQL_ROOT_PASSWORD=thay-bang-mat-khau-manh
ADMIN_PASSWORD=thay-bang-mat-khau-admin-site

# Tên site Frappe (thư mục trong volume sites/)
SITE_NAME=frontend

# URL công khai (HTTPS + cổng nếu khác 443). Không có / ở cuối.
# Ví dụ khi chỉ mở cổng 5454: https://your-domain.com:5454
BASE_URL=https://your-domain.com:5454

ERPNEXT_VERSION=v15

# Cổng host map vào HTTP trong container (bên trong vẫn 8080). Mặc định 5454.
FRONTEND_PORT=5454
# Dev: 0.0.0.0. Production + Nginx trên host: 127.0.0.1
FRONTEND_BIND=0.0.0.0

UPSTREAM_REAL_IP_ADDRESS=172.16.0.0/12

# --- Zalo ---
ZALO_APP_ID=
ZALO_SECRET=
ZALO_OA_ACCESS_TOKEN=
GROUP_ID_ZALO=
ZALO_REDIRECT_URI=/api/method/food_order_app.api.zalo_callback

# App food_order_app: sau khi deploy (docker compose up), exec backend và chạy
# bench get-app <URL_REPO> rồi bench install-app — xem README.
